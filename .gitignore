# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Env and secrets
.env
*.local

# Data (never commit clinical data, even de-identified)
data/*
!data/.gitkeep

# Public-domain CMS reference vocabularies, not clinical data (see P2-3 spec).
# The directory must be re-included first: data/* excludes data/vocab itself,
# and git will not descend into an excluded directory, so a negation naming a
# file inside it cannot re-include the file.
!data/vocab/
!data/vocab/**

# Models and artifacts
*.pt
*.bin
*.onnx
whisper_cache/

# P1-4 eval harness. The cache holds raw model responses over transcripts and
# clinician notes, and the .full.json artifact carries fact text and generated
# notes, so both are clinical data and fall under the rule above. The redacted
# artifact next to it carries verdicts only and IS committed: the headline
# number recomputes from those alone.
governance/.cache/
governance/eval_artifacts/*.full.json

# Node
node_modules/
dashboard/dist/

# OS
.DS_Store

# Local Claude Code agent templates (not project-specific, not wired up)
.claude/

# No notebooks in this repo (hard project rule)
*.ipynb

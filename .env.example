# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Postgres (local docker-compose defaults). Host port is 5433, not 5432:
# some machines already have a native postgres bound to 5432, which
# silently shadows Docker's published port on Windows. In-cluster/CI use
# 5432 normally since there is no such conflict there.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=care_ops
POSTGRES_USER=care_ops
POSTGRES_PASSWORD=change_me

# Whisper transcription model size: tiny, base, small, medium, large-v3.
# Trade accuracy against latency. tiny/base for local dev, larger for accuracy runs.
WHISPER_MODEL_SIZE=base

# Model routing (see shared/llm.py). Override per environment if needed.
MODEL_STRUCTURING=claude-sonnet-5
MODEL_PRIOR_AUTH=claude-sonnet-5
MODEL_CARE_GAP=claude-haiku-4-5-20251001
MODEL_CODING=claude-sonnet-5
MODEL_TRANSPARENCY=claude-haiku-4-5-20251001

# Effort levels: low, medium, high, xhigh, max. Default high.
EFFORT_STRUCTURING=high
EFFORT_PRIOR_AUTH=high
EFFORT_CODING=xhigh

# In-cluster service URLs (docker-compose / k8s service DNS)
INTAKE_URL=http://intake:8000
PRIOR_AUTH_URL=http://agent-prior-auth:8000
CARE_GAP_URL=http://agent-care-gap:8000
CODING_URL=http://agent-coding:8000
